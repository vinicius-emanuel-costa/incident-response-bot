# Token do bot Telegram (obter via @BotFather)
TELEGRAM_TOKEN=seu-token-aqui

# ID do canal/grupo de on-call
ONCALL_CHANNEL_ID=-1001234567890

# ID do canal/grupo de alertas (P1/P2)
ALERT_CHANNEL_ID=-1001234567891

# Caminho do banco de dados
DATABASE_PATH=data/incidents.db

# Timeouts de escalonamento (segundos)
ESCALATION_P1=300
ESCALATION_P2=900
ESCALATION_P3=1800
ESCALATION_P4=3600

# Timezone
TIMEZONE=America/Sao_Paulo
